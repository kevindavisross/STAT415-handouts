compute_stationary_distribution <- function(P){
s = nrow(P)
rep(1, s) %*% solve(diag(s) - P + matrix(rep(1, s * s), ncol = s))
}
P = rbind(c(0, .217, .348, .435),
c(.333, 0, .400, .267),
c(.333, .286, 0, .381),
c(.455, .227, .318, 0))
